{
  "name": "macos-keychain-analysis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "proof:01": "bun run proofs/01-security-cli-create-read-own/proof.ts",
    "proof:01:cleanup": "bun run proofs/01-security-cli-create-read-own/proof.ts --cleanup",
    "proof:02": "bun run proofs/02-keychain-probe-create-read-own/proof.ts",
    "proof:02:cleanup": "bun run proofs/02-keychain-probe-create-read-own/proof.ts --cleanup",
    "keychain-probe:build": "swift build --package-path packages/keychain-probe",
    "keychain-probe:run": "swift run --package-path packages/keychain-probe keychain-probe",
    "proof:03": "bun run proofs/03-read-probe-item-with-security-cli/proof.ts",
    "proof:03:cleanup": "bun run proofs/03-read-probe-item-with-security-cli/proof.ts --cleanup",
    "proof:04": "bun run proofs/04-security-cli-create-probe-read/proof.ts",
    "proof:04:cleanup": "bun run proofs/04-security-cli-create-probe-read/proof.ts --cleanup",
    "proof:04a": "bun run proofs/04a-security-cli-create-probe-read-no-acl/proof.ts",
    "proof:04a:cleanup": "bun run proofs/04a-security-cli-create-probe-read-no-acl/proof.ts --cleanup",
    "proof:04b": "bun run proofs/04b-security-cli-create-probe-acl-only/proof.ts",
    "proof:04b:cleanup": "bun run proofs/04b-security-cli-create-probe-acl-only/proof.ts --cleanup",
    "proof:05": "bun run proofs/05-cross-binary-read-twice/proof.ts",
    "proof:05:cleanup": "bun run proofs/05-cross-binary-read-twice/proof.ts --cleanup",
    "proof:05a": "bun run proofs/05a-cross-binary-read-twice-always-allow/proof.ts",
    "proof:05a:cleanup": "bun run proofs/05a-cross-binary-read-twice-always-allow/proof.ts --cleanup",
    "proof:06": "bun run proofs/06-security-cli-create-trust-probe/proof.ts",
    "proof:06:cleanup": "bun run proofs/06-security-cli-create-trust-probe/proof.ts --cleanup",
    "proof:06a": "bun run proofs/06a-security-cli-create-trust-probe-read-only/proof.ts",
    "proof:06a:cleanup": "bun run proofs/06a-security-cli-create-trust-probe-read-only/proof.ts --cleanup",
    "proof:06b": "bun run proofs/06b-security-cli-create-trust-probe-always-allow/proof.ts",
    "proof:06b:cleanup": "bun run proofs/06b-security-cli-create-trust-probe-always-allow/proof.ts --cleanup",
    "proof:07": "bun run proofs/07-acl-authorization-decoder/proof.ts",
    "proof:07:cleanup": "bun run proofs/07-acl-authorization-decoder/proof.ts --cleanup",
    "proof:08": "bun run proofs/08-partition-list-decoder/proof.ts",
    "proof:08:cleanup": "bun run proofs/08-partition-list-decoder/proof.ts --cleanup",
    "proof:09": "bun run proofs/09-security-cli-set-cdhash-partition/proof.ts",
    "proof:09:cleanup": "bun run proofs/09-security-cli-set-cdhash-partition/proof.ts --cleanup"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
